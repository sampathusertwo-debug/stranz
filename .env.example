# Environment Variables for Docker Setup

# Node Environment
NODE_ENV=production

# Database Configuration
# Set to 'true' to use Supabase, 'false' for local SQLite
USE_SUPABASE=true

# Supabase Configuration (required if USE_SUPABASE=true)
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: Additional Supabase keys
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
